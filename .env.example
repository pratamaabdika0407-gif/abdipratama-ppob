# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ppob_db"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# API Provider PPOB
PPOB_API_URL=https://api.provider.com
PPOB_API_KEY=your-api-key
PPOB_API_SECRET=your-api-secret

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# WhatsApp Configuration
WHATSAPP_WEBHOOK_URL=https://your-domain.com/api/webhook/whatsapp
WHATSAPP_API_KEY=your-whatsapp-api-key

# Firebase Configuration
FIREBASE_API_KEY=your-firebase-key
FIREBASE_AUTH_DOMAIN=your-firebase-domain
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_STORAGE_BUCKET=your-firebase-storage
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# WebSocket
WEBSOCKET_URL=http://localhost:3001

# Storage
NEXT_PUBLIC_STORAGE_BUCKET=uploads

# Stripe (Optional Payment Gateway)
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000