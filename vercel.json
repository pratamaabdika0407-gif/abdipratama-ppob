{
  "name": "ppob-enterprise-vercel",
  "version": "1.0.0",
  "description": "PPOB Enterprise - Vercel Deploy Config",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "env": {
    "DATABASE_URL": {
      "description": "PostgreSQL connection string"
    },
    "NEXTAUTH_URL": {
      "description": "Your domain URL"
    },
    "NEXTAUTH_SECRET": {
      "description": "Generate with: openssl rand -base64 32"
    },
    "PPOB_API_KEY": {
      "description": "PPOB Provider API Key"
    }
  }
}
